# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=gst_billing.production_settings
DEBUG=False

# Database settings
DB_NAME=gst_billing
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis settings
REDIS_HOST=redis
REDIS_PORT=6379

# Other settings
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*

# Docker Hub settings
DOCKER_USERNAME=your-dockerhub-username

# Django superuser settings
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-immediately
# React
REACT_APP_API_URL=http://localhost:8000/api

# AI Invoice Import — Google Gemini (free key at https://aistudio.google.com/apikey).
# Gemini 2.5 Flash on the free tier: 15 RPM, ~1500 req/day, native
# response_schema for shape-guaranteed JSON. The model is overridable
# (e.g. gemini-2.5-pro for slower but more accurate extraction).
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional: NVIDIA NIM as fallback (https://build.nvidia.com). Not
# wired into the active path — utils.py would need to be edited to
# swap providers. Kept here for documentation.
NVIDIA_API_KEY=
NVIDIA_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct