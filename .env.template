# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=gst_billing.production_settings
DEBUG=False

# Database settings
DB_NAME=gst_billing
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis settings
REDIS_HOST=redis
REDIS_PORT=6379

# Other settings
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*

# Docker Hub settings
DOCKER_USERNAME=your-dockerhub-username

# Django superuser settings
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-immediately
# React
REACT_APP_API_URL=http://localhost:8000/api

# AI Invoice Import — Google Gemini (free keys at https://aistudio.google.com/apikey).
# Default model is flash-LITE — benchmarks ~3s per invoice on the free
# tier (vs ~15s for full Flash) with no quality loss on printed invoices.
# Override for hard scans:
#   GEMINI_VISION_MODEL=gemini-2.5-flash      # ~5s, better on phone shots
#   GEMINI_VISION_MODEL=gemini-2.5-pro        # ~15s, best on terrible scans
#
# MULTI-KEY ROTATION: GEMINI_API_KEYS is a comma-separated list. Each
# free-tier Gemini key has its own 20-req/day cap, so N keys = N × 20
# effective daily capacity. Keys can come from different Google
# accounts. The extractor tries each in order, marks 429'd keys as
# cooled down for the retry-after window, and rotates automatically.
GEMINI_API_KEYS=
# Single-key backward compat — appended to GEMINI_API_KEYS if both set.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# Optional NIM fallback when ALL Gemini keys are cooled down. Off by
# default — NIM's vision quality on jewellery invoices is meaningfully
# weaker than Gemini (occasional O/0 character confusions, less
# reliable Hindi handling). Flip to "true" if you'd rather get *some*
# result than a hard error when the whole Gemini pool is exhausted.
AI_NIM_FALLBACK=false
NVIDIA_API_KEY=
NVIDIA_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct