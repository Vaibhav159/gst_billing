# GST Billing - Backend Environment Variables
# Copy this to deploy/backend/.env and fill in values

# === REQUIRED ===
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key
DB_PASSWORD=change-this-to-a-strong-password
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password

# === CORS (Frontend URL) ===
# Set this to your frontend domain (where the React app is hosted)
# Multiple domains separated by commas
CORS_ALLOWED_ORIGINS=https://your-frontend.pages.dev

# === Server ===
DEBUG=False
ALLOWED_HOSTS=your-oracle-server-ip,your-domain.com

# === Database ===
DB_NAME=gst_billing
DB_USER=postgres
DB_HOST=db
DB_PORT=5432

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Admin User ===
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# === Optional ===
# DOCKER_USERNAME=yourusername
# GEMINI_API_KEY=your-gemini-api-key-for-ai-features
